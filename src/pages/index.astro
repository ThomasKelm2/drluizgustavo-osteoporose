<Layout title="Dr. Luiz Gustavo - Especialista em Osteoporose" description="Especialista em osteoporose com 20+ anos de experiência. Tratamento inovador para recuperar densidade óssea e eliminar dor.">
	<Hero />
	<SymptomsSection />
	<AboutSection />
	<CausesSection />
	<div style="width:100%;height:6px;background:linear-gradient(90deg,#2d6b69 0%,#428482 50%,#2d6b69 100%);"></div>
	<TreatmentsSection />
	<CTASection />
	<LocationsSection />
	<div style="width:100%;height:6px;background:linear-gradient(90deg,#2d6b69 0%,#428482 50%,#2d6b69 100%);"></div>
	<Faqsection />
	<Footer />
</Layout>

