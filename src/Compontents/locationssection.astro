---
// src/Components/LocationsSection.astro

const locations = [
  {
    name: "Clínica Artro",
    address: "Av. Vicente Machado, 2439 - Batel",
    city: "Curitiba - PR, 80440-020",
    phone: "(41) 3340-5500",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`
  },
  {
    name: "Hospital XV",
    address: "Rua XV de Novembro, 2223 - Alto da XV",
    city: "Curitiba - PR, 80045-125",
    phone: "(41) 3218-2000",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 8v8M8 12h8"/></svg>`
  },
  {
    name: "Hospital das Nações",
    address: "Rua Raphael Papa, 10 - Jardim Social",
    city: "Curitiba - PR, 82530-190",
    phone: "(41) 3306-9000",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 8v8M8 12h8"/></svg>`
  },
  {
    name: "Clínica Pulsar",
    address: "Rua Emiliano Perneta, 424 - 17º andar - Centro",
    city: "Curitiba - PR, 80420-080",
    phone: "(41) 3387-5859",
    note: "Edifício Top Center Executive",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4M8 6h.01M12 6h.01M16 6h.01M8 10h.01M12 10h.01M16 10h.01M8 14h.01M12 14h.01M16 14h.01"/></svg>`
  }
];
---

<section id="locationssection" class="locations-section">
  <div class="container">

    <div class="header">
      <span class="eyebrow">ONDE NOS ENCONTRAR</span>
      <h2 class="title">
        Locais de <em>Atendimento</em>
      </h2>
      <p class="intro">
        O Dr. Luiz Gustavo atende em quatro clínicas e hospitais de referência em Curitiba.
      </p>
    </div>

    <div class="cards-grid">
      {locations.map((loc) => (
        <div class="card">
          <div class="card-icon" set:html={loc.icon} />
          <div class="card-body">
            <h3 class="card-name">{loc.name}</h3>
            {loc.note && <span class="card-note">{loc.note}</span>}
            <p class="card-address">
              <svg class="pin-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{loc.address}<br />{loc.city}</span>
            </p>
            <a href={`tel:${loc.phone.replace(/\D/g,'')}`} class="card-phone">
              <svg class="phone-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 0h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 7.58a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.46 15z"/></svg>
              {loc.phone}
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .locations-section {
    background-color: #f5f0e8;
    padding: 6rem 2rem;
    font-family: 'Montserrat', sans-serif;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── HEADER ── */
  .header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .eyebrow {
    display: inline-block;
    color: #428482;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1.25rem;
  }

  .title {
    font-family: 'Montserrat', sans-serif;
    color: #1a2f33;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 1.25rem 0;
  }

  .title em {
    font-style: italic;
    font-weight: 400;
    color: #428482;
  }

  .intro {
    color: #4a5568;
    font-size: 0.975rem;
    line-height: 1.75;
    margin: 0 auto;
    max-width: 520px;
  }

  /* ── GRID ── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  /* ── CARD ── */
  .card {
    background-color: #ffffff;
    border-radius: 18px;
    padding: 2rem 2rem 1.75rem 2rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    border-top: 3px solid #428482;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.1);
  }

  .card-icon {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    background-color: #e6f2f1;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #428482;
    padding: 9px;
    box-sizing: border-box;
  }

  .card-icon svg {
    width: 100%;
    height: 100%;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .card-name {
    font-family: 'Montserrat', sans-serif;
    color: #1a2f33;
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .card-note {
    font-size: 0.75rem;
    color: #428482;
    font-weight: 600;
    font-style: italic;
  }

  .card-address {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    color: #4a5568;
    font-size: 0.85rem;
    line-height: 1.55;
    margin: 0.15rem 0 0 0;
  }

  .pin-icon {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    color: #428482;
    margin-top: 2px;
  }

  .card-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #428482;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    margin-top: 0.25rem;
    width: fit-content;
    transition: color 0.2s ease;
  }

  .card-phone:hover {
    color: #2d6b69;
  }

  .phone-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .locations-section {
      padding: 4rem 1.25rem;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }

    .card {
      padding: 1.5rem;
    }
  }
</style>
