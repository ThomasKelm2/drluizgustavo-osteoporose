---

<section class="cta-section" id="ctasection">
  <div class="container">
    
    <span class="eyebrow">Próximo Passo</span>
    
    <p class="title-small">Sua saúde óssea não pode esperar.</p>
    <h2 class="title">
      <span class="highlight">A OSTEOPOROSE TEM SOLUÇÃO.</span>
    </h2>
    
    <p class="subtitle">
      Marque sua consulta, e tenha seu diagnóstico claro e um plano de tratamento personalizado para a osteoporose.
    </p>
    
    <a href="https://wa.me/5541999782006?text=Gostaria%20de%20marcar%20uma%20consulta%20com%20o%20Dr.%20Luiz%20para%20tratar%20a%20sa%C3%BAde%20dos%20meus%20ossos" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
      <svg class="whatsapp-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
        <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157.1zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
      </svg>
      Agendar Minha Consulta
    </a>

    <div class="trust-badges">
      <div class="badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-positividade)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        <span>Atendimento humanizado</span>
      </div>
      <div class="badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-positividade)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
        <span>Consulta particular e por Unimed/Fundação Copel</span>
      </div>
      <div class="badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-positividade)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        <span>Curitiba - PR</span>
      </div>
    </div>

  </div>
</section>

<style>
  :root {
    --color-medicina: #E3EDDB;
    --color-positividade: #F8AE3B;
    --color-cuidado: #10AB7C;
    --color-profissionalismo: #193C40;
    
    /* Um tom levemente mais escuro do profissionalismo para o fundo principal gerar contraste com o centro */
    --color-bg-dark: #122b2e; 
  }

  .cta-section {
    /* Fundo escuro com um gradiente radial suave no centro para dar o efeito de luz da imagem */
    background: radial-gradient(circle at center, var(--color-profissionalismo) 0%, var(--color-bg-dark) 70%);
    padding: 7rem 2rem;
    font-family: 'Montserrat', sans-serif;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── HEADER ── */
  .eyebrow {
    color: var(--color-positividade);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
  }

  .title {
    color: #ffffff;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1.5rem 0;
  }

  .title-small {
    color: rgba(255, 255, 255, 0.75);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    font-weight: 500;
    margin: 0 0 0.6rem 0;
  }

  .title .highlight {
    color: #ffffff;
    /* Efeito de brilho no texto "TEM SOLUÇÃO" */
    text-shadow: 0 0 20px rgba(16, 171, 124, 0.6);
  }

  .subtitle {
    color: var(--color-medicina);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 3rem 0;
    max-width: 600px;
    opacity: 0.9;
  }

  /* ── BOTÃO ── */
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background-color: var(--color-cuidado);
    color: #ffffff;
    text-decoration: none;
    font-size: 1.15rem;
    font-weight: 700;
    padding: 1.25rem 2.5rem;
    border-radius: 50px;
    transition: all 0.3s ease;
    box-shadow: 0 0 25px rgba(16, 171, 124, 0.4);
  }

  .whatsapp-icon {
    width: 22px;
    height: 22px;
    fill: currentColor;
    flex-shrink: 0;
  }

  .btn-whatsapp:hover {
    transform: scale(1.02) translateY(-2px);
    background-color: #0d8f68; /* Levemente mais escuro no hover */
    box-shadow: 0 0 35px rgba(16, 171, 124, 0.6);
  }

  /* ── TRUST BADGES (Rodapé da seção) ── */
  .trust-badges {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    margin-top: 4rem;
  }

  .badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-medicina);
    font-size: 0.85rem;
    opacity: 0.8;
  }

  /* ── RESPONSIVO ── */
  @media (max-width: 768px) {
    .cta-section {
      padding: 5rem 1.5rem;
    }
    
    .btn-whatsapp {
      width: 100%;
      font-size: 1rem;
      padding: 1.1rem 1.5rem;
    }

    .trust-badges {
      flex-direction: column;
      gap: 1.25rem;
      margin-top: 3rem;
      align-items: center;
      width: 100%;
    }
  }
</style>