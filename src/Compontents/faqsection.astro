---
// src/components/FAQSection.astro

const faqItems = [
  {
    icon: "⚖️", // Você pode substituir por um SVG correspondente ao projeto
    title: "O valor do investimento em saúde",
    description: "O atendimento particular proporciona o tempo e a atenção necessários para uma avaliação minuciosa. O investimento em um diagnóstico correto e tratamento precoce é significativamente inferior aos custos físicos, emocionais e financeiros de uma complicação futura."
  },
  {
    icon: "⏱️",
    title: "Protocolos modernos adaptáveis à sua rotina",
    description: "Os tratamentos atuais para o manejo da osteoporose são práticos. Utilizamos terapias modernas que variam de administrações semanais a semestrais, aliadas a orientações que se integram ao seu cotidiano, garantindo a eficácia sem comprometer sua agenda."
  },
  {
    icon: "🛡️",
    title: "A importância clínica da avaliação preventiva",
    description: "A osteoporose é uma condição silenciosa em seus estágios iniciais. Aguardar o surgimento de dor ou o agravamento do quadro para buscar ajuda especializada não é o protocolo ideal. A avaliação preventiva é o caminho mais seguro para a longevidade da sua saúde óssea."
  }
];
---

<section id="faqsection" class="faq-section">
  <div class="container">
    
    <div class="header">
      <span class="eyebrow">TRANSPARÊNCIA E CLAREZA</span>
      <h2 class="title">
        Informações essenciais antes de<br />
        <em>iniciar seu acompanhamento.</em>
      </h2>
    </div>

    <div class="faq-grid">
      {faqItems.map((item) => (
        <div class="faq-card">
          <h3 class="faq-title">{item.title}</h3>
          <p class="faq-text">{item.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  :root {
    /* Cores extraídas do Guia de Marca */
    --color-medicina: #E3EDDB;        /* Verde bem claro - Fundo suave */
    --color-positividade: #F8AE3B;    /* Amarelo/Laranja - Destaques quentes */
    --color-cuidado: #10AB7C;         /* Verde vibrante - Ícones e links */
    --color-profissionalismo: #193C40;/* Verde escuro - Textos e Títulos */
  }

  .faq-section {
    background-color: #f1f1f1;
    padding: 6rem 2rem;
    font-family: 'Montserrat', sans-serif;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── HEADER ── */
  .eyebrow {
    display: block;
    color: var(--color-cuidado);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1rem;
    text-align: center;
  }

  .title {
    color: var(--color-profissionalismo);
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 4rem 0;
    text-align: center;
  }

  .title em {
    font-size: clamp(1.5rem, 1.5vw, 1.2rem);
    line-height: 0.75;
    font-style: italic;
    font-weight: 600;
    color: var(--color-cuidado);
  }

  /* ── FAQ GRID ── */
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .faq-card {
    background-color: #ffffff;
    border-radius: 12px;
    padding: 2.5rem 2rem;
    box-shadow: 0 4px 20px rgba(25, 60, 64, 0.04);
    border-top: 4px solid var(--color-positividade); /* Toque de cor da marca */
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .faq-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(25, 60, 64, 0.08);
  }

  .faq-title {
    color: var(--color-profissionalismo);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
  }

  .faq-text {
    color: #4a5568; /* Cinza escuro para melhor legibilidade no corpo do texto */
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  /* ── RESPONSIVO ── */
  @media (max-width: 900px) {
    .faq-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .faq-section {
      padding: 4rem 1.5rem;
    }
    
    .faq-grid {
      grid-template-columns: 1fr;
    }
    
    .faq-card {
      padding: 2rem 1.5rem;
    }
  }
</style>