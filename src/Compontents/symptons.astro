---
// src/Components/Symptons.astro

const symptoms = [
  {
    icon: "🦴",
    title: "Dor persistente nas costas ou coluna",
    description: "Aquela dor que não passa nem com repouso, que piora ao se movimentar e que ninguém conseguiu explicar direito até hoje.",
    tag: "DOR CRÔNICA • COLUNA",
    highlight: false
  },
  {
    icon: "⚠️",
    title: "Fratura por um trauma pequeno",
    description: "Quebrou um osso em uma queda simples ou por um impacto leve? Isso pode indicar que os ossos estão mais frágeis do que deveriam.",
    tag: "FRATURA • FRAGILIDADE ÓSSEA",
    highlight: true
  },
  {
    icon: "📏",
    title: "Sensação de que está perdendo altura",
    description: "Parece que você encolheu alguns centímetros ao longo dos anos? Isso pode ser sinal de compressão vertebral relacionada à osteoporose.",
    tag: "COMPRESSÃO VERTEBRAL",
    highlight: false
  },
  {
    icon: "😮‍💨",
    title: "Cansaço e fraqueza muscular",
    description: "Uma fraqueza que vai além do sedentarismo — músculos que parecem não responder bem e cansaço físico desproporcional ao esforço.",
    tag: "FRAQUEZA MUSCULAR • FADIGA",
    highlight: false
  },
  {
    icon: "🩺",
    title: "Outro médico indicou um especialista",
    description: "Se seu clínico, ginecologista ou endocrinologista disse que você deveria procurar um ortopedista para avaliar seus ossos, esse é o lugar certo.",
    tag: "ENCAMINHAMENTO MÉDICO",
    highlight: false
  },
  {
    icon: "🧬",
    title: "Histórico familiar ou fatores de risco",
    description: "Mãe ou avó com osteoporose? Uso prolongado de corticoides? Menopausa precoce? Esses fatores aumentam significativamente o risco.",
    tag: "GENÉTICA • FATORES DE RISCO",
    highlight: false
  }
];
---

<section class="symptoms-section">
  <div class="container">
    
    <div class="header-text">
      <span class="eyebrow">RECONHEÇA OS SINAIS</span>
      <h2 class="title">Sinais que o seu corpo pode estar pedindo atenção</h2>
      <p class="subtitle">Muitas pessoas convivem com esses sintomas por meses, ou anos sem saber que existe um diagnóstico e um tratamento eficaz. Se você se reconhecer em algum deles, vale marcar uma avaliação.</p>
    </div>

    <div class="grid">
      {symptoms.map((symptom) => (
        <article class={`card ${symptom.highlight ? 'highlight' : ''}`}>
          <div class="icon-box">
            {symptom.icon}
          </div>
          <h3 class="card-title">{symptom.title}</h3>
          <p class="card-desc">{symptom.description}</p>
          <span class="card-tag">{symptom.tag}</span>
        </article>
      ))}
    </div>

    <div class="cta-section">
      <h3 class="cta-quote">Se identificou com algum destes sintomas?</h3>
      <a href="https://wa.me/5541999782006?text=Gostaria%20de%20marcar%20uma%20consulta%20com%20o%20Dr.%20Luiz%20para%20tratar%20a%20sa%C3%BAde%20dos%20meus%20ossos" target="_blank" rel="noopener noreferrer" class="cta-button">
        <svg class="whatsapp-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
          <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157.1zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
        </svg>
        AGENDAR CONSULTA
      </a>
    </div>

  </div>
</section>

<style>
  .symptoms-section {
    background-color: #ffffff;
    padding: 6rem 1rem;
    text-align: center;
    font-family: 'Montserrat', sans-serif;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }

  .header-text {
    margin-bottom: 4rem;
  }

  .eyebrow {
    color: #428482;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    display: block;
    margin-bottom: 1rem;
  }

  .title {
    color: #1a3b3b;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 1rem 0;
  }

  .subtitle {
    color: #666666;
    font-size: 0.9rem;
    max-width: 680px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .card {
    background-color: #f8fbf9;
    border: 1px solid #eef2f0;
    border-left: 4px solid #428482;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.12);
  }

  .card.highlight {
    background-color: #f8fbf9;
    border-left-color: #428482;
  }

  .icon-box {
    background-color: #1a2f33;
    color: #ffffff;
    width: 32px;
    height: 32px;
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .card-title {
    color: #1a3b3b;
    font-size: 1.05rem;
    font-weight: 800;
    margin: 0 0 0.6rem 0;
    line-height: 1.3;
  }

  .card-desc {
    color: #555555;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 1.25rem 0;
    flex-grow: 1;
  }

  .card-tag {
    background-color: #e6f2ed;
    color: #3b8b88;
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .cta-section {
    margin-top: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .cta-quote {
    color: #1a1a1a;
    font-size: 1.8rem;
    font-weight: 800;
    max-width: 400px;
    margin: 0;
    line-height: 1.25;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background-color: #1a3b3b;
    color: #ffffff;
    text-decoration: none;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    transition: background-color 0.3s ease, transform 0.2s ease;
    width: fit-content;
  }

  .cta-button:hover {
    background-color: #2a5555;
    transform: translateY(-2px);
  }

  .cta-button:focus-visible {
    outline: 3px solid rgba(0, 0, 0, 0.12);
    outline-offset: 3px;
  }

  .whatsapp-icon {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  @media (max-width: 992px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .symptoms-section {
      padding: 4rem 1rem;
    }
    .card.highlight {
      border-left: 1px solid #eef2f0;
    }
    .cta-quote {
      font-size: 1.1rem;
    }
  }
</style>